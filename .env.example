# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

SUPABASE_URL=https://poqlobkzaxrbwqjqxegn.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBvcWxvYmt6YXhyYndxanF4ZWduIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI0NzE0MjUsImV4cCI6MjA4ODA0NzQyNX0.ZIu_Zf1WaiBMa_ELcugXj6i_bRf5pq27mIOPBamRFh4

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
OPENAI_SECRET_KEY=your-openai-secret-key-here
ASAAS_WEBHOOK_SECRET=defina-um-segredo-para-validar-o-webhook

# Softphone / PBX
# Enable the resident softphone shell in the app UI.
VITE_SOFTPHONE_ENABLED=false

# When true, the resident shell tries to stay active right after app login.
VITE_SOFTPHONE_AUTO_CONNECT=true

# If true, only residents with internet_active=true will auto-start the softphone shell.
VITE_SOFTPHONE_REQUIRE_INTERNET_ACTIVE=true

# PBX connection placeholders. Fill these after the PBX is installed.
VITE_SOFTPHONE_PBX_HOST=pbx.seu-hostel.local
VITE_SOFTPHONE_PBX_DOMAIN=pbx.seu-hostel.local
VITE_SOFTPHONE_PBX_WSS_URL=wss://pbx.seu-hostel.local:8089/ws
VITE_SOFTPHONE_DEFAULT_DISPLAY_NAME=MoronaVila Softphone
VITE_SOFTPHONE_TRANSPORT=mock

# Server-side placeholder used by the local backend when the browser needs SIP credentials.
# Keep this out of the frontend bundle and fill it only after PBX provisioning.
SOFTPHONE_PBX_DEFAULT_SECRET=trocar-quando-o-pbx-estiver-pronto

# Internal directory defaults
VITE_SOFTPHONE_PORTARIA_EXTENSION=100
VITE_SOFTPHONE_ADMIN_EXTENSION=101
VITE_SOFTPHONE_LAUNDRY_EXTENSION=102
VITE_SOFTPHONE_DELIVERY_EXTENSION=103

# Door opening integration placeholders
VITE_SOFTPHONE_DOOR_MODE=none
VITE_SOFTPHONE_DOOR_LABEL=Abrir porta
VITE_SOFTPHONE_DOOR_DTMF=9
SOFTPHONE_DOOR_RELAY_URL=



